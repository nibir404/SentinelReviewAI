NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://sentinel:sentinel_dev_password@localhost:5432/sentinel_review_ai

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# API
API_KEY=your-api-key-here

# Git Providers
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITLAB_WEBHOOK_SECRET=your-gitlab-webhook-secret
BITBUCKET_WEBHOOK_SECRET=your-bitbucket-webhook-secret
AZURE_WEBHOOK_SECRET=your-azure-webhook-secret

# GitHub
GITHUB_TOKEN=your-github-token

# GitLab
GITLAB_TOKEN=your-gitlab-token

# Azure DevOps
AZURE_ORGANIZATION=your-organization
AZURE_TOKEN=your-azure-token

# AI
OPENAI_API_KEY=your-openai-api-key
AI_MODEL=gpt-4
MAX_FILE_SIZE=1048576

# Frontend
FRONTEND_URL=http://localhost:3000
